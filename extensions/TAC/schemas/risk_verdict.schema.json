{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tac.local/schemas/risk_verdict.schema.json",
  "title": "RiskVerdict",
  "type": "object",
  "required": [
    "session_id",
    "stage",
    "as_of_ts",
    "verdict",
    "risk_level",
    "degraded_mode",
    "confidence",
    "blocking_reasons"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "const": "risk_chain"
    },
    "as_of_ts": {
      "type": "string",
      "format": "date-time"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "APPROVE",
        "REVISE",
        "REJECT"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "degraded_mode": {
      "type": "string",
      "enum": [
        "NONE",
        "PARTIAL_DATA",
        "STALE_DATA"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "verdict": {
            "const": "REJECT"
          }
        },
        "required": [
          "verdict"
        ]
      },
      "then": {
        "properties": {
          "blocking_reasons": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}

